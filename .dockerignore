# Dependencias — siempre se instalan dentro del contenedor
node_modules

# Control de versiones
.git
.gitignore

# Variables de entorno — nunca deben entrar a la imagen
.env
.env.*
.env.local
server/.env

# Carpeta del cliente React — tiene su propio Dockerfile en client/
client/

# Tests y colecciones Postman — no necesarios en producción
tests/
postman/

# Documentación
README.md
eslint.config.js

# Logs
*.log
npm-debug.log*

# Artefactos de build
coverage/
dist/
build/

# Archivos de sistema operativo
.DS_Store
Thumbs.db

# Archivos de Claude Code (configuración local del editor)
.claude/